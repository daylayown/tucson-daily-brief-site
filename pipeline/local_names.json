{
  "_meta": {
    "purpose": "Canonical names and places for Southern Arizona municipalities. Loaded by ai_reporter.py and injected into the news-report generation prompt to correct Deepgram mistranscriptions.",
    "last_updated": "2026-07-14",
    "deepgram_misreads_note": "Each known misread observed in a transcript should be added to the `deepgram_misreads` array. The pipeline will tell the LLM to replace any of these with the canonical form.",
    "verification_needed": [
      "regional.people: Suzanne Droubie (Pima County Assessor) — re-verify on pima.gov before relying on",
      "pima-county.people: Dan Hunt (CIO) — most recent direct confirmation was 2022; re-verify",
      "pima-county.people: pronouns unset for Carmine DeBonis Jr., Monica Perez, Art Cuaron, Jackson Jenkins, Dan Hunt — confirm on pima.gov before adding (do not infer from name)",
      "regional.people: pronouns unset for Suzanne Droubie, Joe Snell, Laurie Kierstead-Joseph, John Cross, JD Wallace",
      "pima-county.people: Michael Racy — Deepgram rendered as 'Rossi'/'Rask'; confirm current Pima County lobbying contract status"
    ],
    "scope_note": "Regional bucket also holds state-level officials (e.g., Arizona Auditor General) since they appear at any municipality's meetings and don't belong in any single municipality bucket.",
    "pronouns_note": "Pronouns are injected so the model does not infer gender from a name (root cause of a 2026-07-14 Pima County draft misgendering Supervisor Andrés Cano). Only add pronouns that are evidenced — transcript honorifics/pronoun use, or documented public record. If unknown, leave the field off and add the person to verification_needed rather than guessing."
  },
