# Keep the Fly build context small. The Dockerfile only COPYs a handful of
# rag/ files (including index.sqlite), so exclude everything heavy here.
.git
.venv
**/__pycache__
*.pyc
*.log

# Site content + working dirs the Ask service doesn't need.
posts
meeting-watch
news-reports
public-record
agenda-watch
transcripts
newsletter
people-photos
crossword
*.html

# Build state that must never leak into the image.
rag/__pycache__
